{
    "compilerOptions": {
        "target": "ES2022",

        "module": "ESNext",
        "moduleResolution": "Bundler",

        "strict": true,

        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,

        "resolveJsonModule": true,

        "skipLibCheck": true,

        "forceConsistentCasingInFileNames": true,

        "declaration": true,

        "sourceMap": true
    }
}
