{
    "$schema": "https://json.schemastore.org/prettierrc",

    "printWidth": 100,

    "tabWidth": 4,

    "useTabs": false,

    "semi": true,

    "singleQuote": true,

    "quoteProps": "as-needed",

    "jsxSingleQuote": true,

    "trailingComma": "all",

    "bracketSpacing": true,

    "bracketSameLine": false,

    "arrowParens": "always",

    "endOfLine": "lf",

    "proseWrap": "preserve",

    "htmlWhitespaceSensitivity": "css"
}
