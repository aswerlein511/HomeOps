# Auto detect text files and normalize line endings
* text=auto

# Source files
*.ts text
*.tsx text
*.js text
*.jsx text
*.css text
*.scss text
*.html text
*.json text
*.md text
*.yml text
*.yaml text
*.xml text

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg text

# Fonts
*.woff binary
*.woff2 binary
*.ttf binary
