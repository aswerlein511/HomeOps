{
    "name": "home-operations-center",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "description": "Home Operations Center Dashboard",
    "author": "",
    "license": "MIT",
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "typecheck": "tsc --noEmit",
        "lint": "eslint . --fix",
        "format": "prettier --write .",
        "test": "vitest",
        "test:watch": "vitest --watch",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "test:e2e:headed": "playwright test --headed",
        "clean": "rimraf dist coverage playwright-report test-results node_modules/.vite",
        "prepare": "husky"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@homeops/shared": "*",
        "@mui/icons-material": "^7.2.0",
        "@mui/material": "^7.2.0",
        "@tanstack/react-query": "^5.85.5",
        "axios": "^1.11.0",
        "lucide-react": "^0.540.0",
        "react": "^19.1.1",
        "react-dom": "^19.1.1",
        "react-hook-form": "^7.62.0",
        "react-router-dom": "^7.8.2",
        "recharts": "^3.1.2",
        "systeminformation": "^5.31.17",
        "zod": "^4.0.17",
        "zustand": "^5.0.7"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.0",
        "@playwright/test": "^1.54.2",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^24.3.0",
        "@types/react": "^19.1.10",
        "@types/react-dom": "^19.1.7",
        "@vitejs/plugin-react": "^5.0.2",
        "@vitest/coverage-v8": "^3.2.7",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "lint-staged": "^16.1.5",
        "prettier": "^3.6.2",
        "rimraf": "^6.0.1",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.42.0",
        "vite": "^7.1.2",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^3.2.7"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{js,mjs,cjs,json,css,scss,md,yml,yaml}": [
            "prettier --write"
        ]
    }
}
